@model Product

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">

            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Inverse table</h4>
                        <p class="card-description">
                            Add class <code>.table-dark</code>
                        </p>
<label>Name:</label>
<p>@Model.Name</p>
<label>Count:</label>
<p>@Model.Count</p>
<label>Price:</label>
<p>@Model.Price</p>
<label>Size:</label>
<p>@Model.Size</p>

<label>Discount</label>
<p>@Model.Discount</p>
<label>Category:</label>
<p>@Model.Category.Name</p>
<label>Color:</label>
@foreach (var color in Model.ColorProducts)
{
    <p>@color.Color.ColorName</p>
}

<label>Images:</label>
@foreach (var item in Model.ProductImages)
{

    <img src="@item.ImageUrl" alt="Product Image" style="max-width: 200px; max-height: 200px;border-radius:50%;" />
}
                        <a asp-controller="Product" asp-action="Index">Back</a>
</<div>
    </div>
</div>


