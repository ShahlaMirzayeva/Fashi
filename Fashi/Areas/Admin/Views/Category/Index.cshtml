
@model IEnumerable<CategoryDto>
<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">

            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Inverse table</h4>
                        <a asp-controller="Category" asp-action="Create">Add Category</a>
                        <div class="table-responsive pt-3">
                            <table class="table table-dark">
                                <thead>
                                    <tr>
                                        <th>
                                            #
                                        </th>
                                        <th>
                                            Name
                                        </th>
                                        <th>
                                           Gender
                                        </th>
                                        <th>
                                            Options
                                        </th>

                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        int count = 0;
                                        foreach (var item in Model)

                                        {
                                            <tr>
                                                <td>
                                                    @{
                                                        count += 1;
                                                    }
                                                    @count
                                                </td>
                                                <td>
                                                    @item.Name
                                                </td>
                                                <td>
                                                    @item.GenderName
                                                </td>
                                                <td>
                                                    <a class="btn btn-primary" asp-controller="Category" asp-action="Update" asp-route-id="@item.Id">Edit</a>
                                                    <a class="btn btn-danger" asp-controller="Category" asp-action="Delete" asp-route-id="@item.Id">Delete</a>

                                                </td>

                                            </tr>
                                        }
                                    }


                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>


