@model IEnumerable<Product>
<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">

            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Inverse table</h4>
                        <a asp-controller="Product" asp-action="Create">Add Product</a>
                        <div class="table-responsive pt-3">
                            <table class="table table-dark">
                                <thead>
                                    <tr>
                                        <th>
                                            #
                                        </th>
                                        <th>
                                            Name
                                        </th>
                                        <th>
                                       Price
                                        </th>
                                        <th>
                                         Discount
                                        </th>
                                        <th>
                                         Count
                                        </th>
                                        <th>
                                         Size
                                        </th>
                                        <th>
                                            Images
                                        </th>
                                        <th>Color</th>
                                        <th>
Category                                        </th>
                                        <th>
                                            Options
                                        </th>

                                    </tr>
                                </thead>
                                <tbody>

                                    @{
                                        int count = 0;
                                        foreach (var item in Model)

                                        {
                                            <tr>
                                                <td>
                                                    @{
                                                        count += 1;
                                                    }
                                                    @count
                                                </td>
                                                <td>
                                                    @item.Name
                                                </td>
                                                <td>
                                                   @item.Price
                                                </td>
                                                <td>
                                                    @item.Discount
                                                </td>
                                                <td>
                                                    @item.Count
                                                </td>
                                                <td>
                                                    @item.Size
                                                </td>
                                                <td>
                                                  @if(item.ProductImages != null && item.ProductImages.Any())
                                                    {
                                                        <img src="@item.ProductImages.First().ImageUrl" alt="Product Image" style="width: 50px; height: 50px;" />
                                                    }
                                                    else
                                                    {
                                                        <span>No Image</span>
                                                    }
        )
                                                </td>
                                                @if(item.ColorProducts != null && item.ColorProducts.Any())
                                                    {
                                                        <td> @item.ColorProducts.First().Color.ColorName </td>                    
                                                    }
                                                   
                                                        
                                                    

                                                <td>
                                                    @item.Category.Name
                                                </td>
                                                <td>
                                                    <a class="btn btn-primary" asp-controller="Product" asp-action="Update" asp-route-id="@item.Id">Edit</a>
                                                    <a class="btn btn-danger" asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                                                    <a class="btn btn-info" asp-controller="Product" asp-action="Detail" asp-route-id="@item.Id">Detail</a>


                                                </td>

                                            </tr>
                                        }
                                    }


                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>



